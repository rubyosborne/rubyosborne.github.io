---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Ruby Osborne',
  description = 'Lying on the forest floor, looking up.',
} = Astro.props;
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0e0c08" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" sizes="any" href="/favicon.png?v=3" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=3" />
  </head>
  <body>
    <slot />
  </body>
</html>
