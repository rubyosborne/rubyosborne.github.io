---
import fs from 'node:fs';
import path from 'node:path';
import Base from '../layouts/Base.astro';
import '../styles/theme.css';

const imgExts = ['jpg', 'jpeg', 'png', 'webp', 'gif'];
const listImages = (dir) => {
  const abs = path.resolve('public', dir);
  if (!fs.existsSync(abs)) return [];
  return fs.readdirSync(abs).filter((f) => imgExts.includes(f.split('.').pop()?.toLowerCase())).sort().map((f) => `/${dir}/${f}`);
};
const cookies = listImages('me/cookies');
const kitchen = listImages('me/kitchen');

const marketsNotes = [
  'Physical AI: robotics, machine vision and sensing.',
  'The AI infrastructure build-out underneath it all.',
  'Security for AI: protecting the apps and the agents.',
  'A bit of China, a bit of space, and the odd asymmetric bet.',
];

const interests = [
  { emoji: '🌿', label: 'Chinese herbal medicine' },
  { emoji: '🥑', label: 'Nutrition' },
  { emoji: '🥾', label: 'Nature & hiking' },
  { emoji: '🏊', label: 'Triathlon' },
  { emoji: '🧘', label: 'Yoga' },
  { emoji: '🏂', label: 'Snowboarding' },
  { emoji: '🎧', label: 'Podcasts' },
  { emoji: '🍲', label: 'Making food for friends' },
];

const podcasts = [
  { name: 'Moonshots with Peter Diamandis', note: 'exponential tech & the future' },
  { name: 'Huberman Lab', note: 'health & performance science' },
];

const recipe = {
  name: 'Sourdough',
  blurb:
    "The thing I always make. It takes time, which is the point, and a warm loaf is a lovely thing to give people or bring to a dinner party. Everyone loves it.",
};

const admire = [
  { name: 'Dr Amanda Williamson', note: 'My mentor and cheerleader, and genuinely brilliant.' },
  { name: 'Mia Ware', note: 'The most resilient person I know, steady in the face of anything.' },
  { name: 'Grace Brown', note: 'Founder of Andromeda, building robots for the good of people.' },
];

const awards = [
  {
    title: 'Winner: Multinational Partner Rising Star, NZ Women in ICT 2026',
    body: 'Named Multinational Partner Rising Star Winner at the Reseller News New Zealand Women in ICT Awards (WIICTA) 2026, the longest-running celebration of women in tech across the region.',
  },
  {
    title: 'Rising Star: Deloitte Asia Pacific Women in Technology',
    body: 'Rising Star in the Deloitte Asia Pacific Women in Technology Awards. At Deloitte New Zealand, I lead Physical AI and the NVIDIA alliance.',
  },
  {
    title: '3rd place, Iron Māori Triathlon, Napier',
    body: 'Podium finish at the Iron Māori triathlon in Napier: swim, bike, run.',
  },
];

const hikes = [
  { src: '/me/hikes/blue-lake.jpg', label: 'Blue Lake' },
  { src: '/me/hikes/kepler.jpg', label: 'The Kepler Track' },
];
const nextRace = { name: 'the Queenstown Marathon', iso: '2026-11-14' };

const socials = [
  { label: 'X', href: 'https://x.com/rubyosb21082829?s=11' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/ruby-osborne-167339166/' },
];
---

<Base title="Myself · Ruby Osborne" description="A little about Ruby Osborne: what she's into, building, and bribeable with (cookies).">
  <script is:inline>document.documentElement.classList.add('js');</script>

  <nav class="nav" aria-label="Sections">
    <a href="#into">Into</a>
    <a href="#people">People</a>
    <a href="#awards">Awards</a>
    <a href="#racing">Racing</a>
    <a href="#hello">Say hi</a>
  </nav>

  <main class="me">
    <a class="back" href="/">← canopy</a>

    <header class="hero reveal">
      <h1>myself</h1>
      <span class="hero-rule" aria-hidden="true"></span>
      <p class="wip">UI in design · cool things coming soon</p>
    </header>

    <div class="bento">
      <!-- what I'm into -->
      <!-- what I'm into (interests + interested-in themes, combined) -->
      <section class="box reveal span2" id="into">
        <h2 class="box-title">what I'm into atm</h2>
        <ul class="interests">
          {interests.map((i) => (
            <li><span class="emoji">{i.emoji}</span><span>{i.label}</span></li>
          ))}
        </ul>

        <h3 class="subh gap">interested in</h3>
        <p class="hint-line">themes from my investing ops, <a class="inline-link" href="/work?p=investing-newsletter">read &amp; subscribe →</a></p>
        <ul class="now">
          {marketsNotes.map((n) => <li>{n}</li>)}
        </ul>
      </section>

      <!-- in my ears -->
      <section class="box reveal span2">
        <h2 class="box-title">in my ears</h2>
        <div class="podpair">
          {podcasts.map((p) => (
            <div class="pod"><span class="row-h">{p.name}</span>{p.note && <span class="row-s">{p.note}</span>}</div>
          ))}
        </div>
      </section>

      <!-- in the kitchen -->
      <section class="box reveal span2">
        <h2 class="box-title">in the kitchen</h2>
        <span class="lead-name">{recipe.name}</span>
        <p class="lead-blurb">{recipe.blurb}</p>
        {kitchen.length > 0 && (
          <div class="pic-row three">
            {kitchen.map((src) => <img src={src} alt="a sourdough loaf" loading="lazy" />)}
          </div>
        )}
      </section>

      <!-- people I admire -->
      <section class="box reveal span2" id="people">
        <h2 class="box-title">people I admire</h2>
        <ul class="rows">
          {admire.map((a) => (
            <li><span class="row-h">{a.name}</span><span class="row-s">{a.note}</span></li>
          ))}
        </ul>
      </section>

      <!-- proud moments -->
      <section class="box reveal span2" id="awards">
        <h2 class="box-title">proud moments</h2>
        <ul class="awards">
          {awards.map((a) => (
            <li>
              <span class="award-title">{a.title}</span>
              <span class="award-body">{a.body}</span>
            </li>
          ))}
        </ul>
      </section>

      <!-- trails & racing -->
      <section class="box reveal span2" id="racing">
        <h2 class="box-title">trails & racing</h2>
        <p class="subh">my favourite hikes</p>
        <div class="hikes">
          {hikes.map((h) => (
            <figure class="hike">
              <img src={h.src} alt={h.label} loading="lazy" />
              <figcaption>{h.label}</figcaption>
            </figure>
          ))}
        </div>
        <p class="race" id="race" data-iso={nextRace.iso} data-name={nextRace.name}></p>
      </section>

      <!-- say hi -->
      <section class="box cookies reveal span2" id="hello">
        <h2 class="box-title">say hi 🍪</h2>
        <p class="cookie-pitch">
          I run almost entirely on cookies. Bribe me with one, tell me something interesting,
          or just say hi, it lands straight in my Slack.
        </p>
        {cookies.length > 0 && (
          <div class="cookie-strip">
            {cookies.map((src) => <img src={src} alt="a favourite cookie" loading="lazy" />)}
          </div>
        )}
        <form class="contact" id="contact" novalidate>
          <div class="row">
            <input class="in" type="text" name="name" placeholder="your name" autocomplete="name" />
            <input class="in" type="email" name="email" placeholder="email (optional)" autocomplete="email" />
          </div>
          <textarea class="in area" name="message" rows="4" placeholder="say something nice (or recommend me a cookie)" required></textarea>
          <div class="row end">
            <p class="contact-msg" role="status" aria-live="polite"></p>
            <button class="btn-solid" type="submit">Send 🍪</button>
          </div>
        </form>
        <div class="findme">
          <span class="subh">find me</span>
          <div class="socials">
            {socials.map((s) => (
              <a class="social" href={s.href} target="_blank" rel="noopener">{s.label} ↗</a>
            ))}
          </div>
        </div>
      </section>
    </div>

    <footer class="me-foot">© 2026 Ruby Osborne · built in the canopy</footer>
  </main>
</Base>

<script>
  // Contact form → Slack (optimistic)
  const form = document.getElementById('contact') as HTMLFormElement | null;
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const f = e.target as HTMLFormElement;
      const msg = f.querySelector('.contact-msg') as HTMLElement;
      const data = {
        name: (f.elements.namedItem('name') as HTMLInputElement).value.trim(),
        email: (f.elements.namedItem('email') as HTMLInputElement).value.trim(),
        message: (f.elements.namedItem('message') as HTMLTextAreaElement).value.trim(),
      };
      if (!data.message) { msg.textContent = 'Add a message first 🙂'; msg.classList.add('err'); return; }
      msg.classList.remove('err');
      msg.textContent = 'Sending…';
      try {
        const r = await fetch('/api/contact', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
        if (!r.ok) throw new Error('bad');
        msg.textContent = 'Got it, thank you! 🍪';
        f.reset();
      } catch {
        msg.textContent = 'Got it, thank you! 🍪';
        f.reset();
      }
    });
  }

  // Live race countdown
  const race = document.getElementById('race');
  if (race) {
    const iso = race.dataset.iso;
    const name = race.dataset.name || 'race day';
    if (iso) {
      const days = Math.ceil((new Date(iso + 'T00:00:00').getTime() - Date.now()) / 86400000);
      race.textContent = days > 0 ? `⏱ ${days} days to ${name}` : `${name}, it's race week!`;
    }
  }

  // Gentle reveal on entry + scrollspy nav
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const reveals = Array.from(document.querySelectorAll('.reveal'));
  if (reduce) {
    reveals.forEach((el) => el.classList.add('in-view'));
  } else {
    const io = new IntersectionObserver(
      (entries) => entries.forEach((e) => {
        if (e.isIntersecting) { e.target.classList.add('in-view'); io.unobserve(e.target); }
      }),
      { threshold: 0.1, rootMargin: '0px 0px -6% 0px' }
    );
    reveals.forEach((el) => io.observe(el));
  }

  const navLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.nav a'));
  const linkFor = new Map(navLinks.map((a) => [a.getAttribute('href')!.slice(1), a]));
  const spy = new IntersectionObserver(
    (entries) => entries.forEach((e) => {
      if (e.isIntersecting) {
        navLinks.forEach((a) => a.classList.remove('active'));
        linkFor.get((e.target as HTMLElement).id)?.classList.add('active');
      }
    }),
    { rootMargin: '-45% 0px -50% 0px', threshold: 0 }
  );
  ['into', 'people', 'awards', 'racing', 'hello'].forEach((id) => {
    const el = document.getElementById(id);
    if (el) spy.observe(el);
  });
</script>

<style>
  /* ── The calm cream room (one daylight source + matte plaster) ── */
  :global(body) {
    background-color: var(--cream);
    background-image: var(--daylight);
    background-attachment: fixed;
    color: var(--ink);
  }
  :global(body)::before {
    content: '';
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background-image: var(--plaster);
    background-size: 220px 220px;
    opacity: 0.05;
    mix-blend-mode: multiply;
  }

  .me {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 clamp(1.2rem, 5vw, 2rem) 6rem;
    color: var(--ink);
    font-family: var(--sans);
  }
  .back {
    display: inline-block;
    color: var(--clay);
    text-decoration: none;
    font-family: var(--serif);
    font-size: 1.1rem;
    letter-spacing: 0.02em;
    margin: clamp(1.4rem, 4vw, 2.5rem) 0 0;
  }
  .back:hover { color: var(--ox-blood); }

  /* ── Hero ── */
  .hero { padding: clamp(2.5rem, 8vw, 5rem) 0 clamp(2rem, 5vw, 3rem); }
  .hero h1 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(3rem, 11vw, 6rem);
    line-height: 0.92;
    margin: 0;
    text-transform: lowercase;
    color: var(--ox-blood);
  }
  .hero-rule { display: block; width: 68px; height: 3px; margin-top: 1.4rem; border-radius: 2px; background: var(--ox-blood); }
  .wip {
    display: inline-block;
    margin: 1.3rem 0 0;
    padding: 0.55em 1em;
    border-radius: 8px;
    background: #1c1714;
    color: var(--bone);
    font-family: var(--sans);
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    box-shadow: var(--shadow-1);
  }

  /* ── Bento grid of boxes ── */
  .bento { display: grid; grid-template-columns: 1fr; gap: clamp(0.9rem, 2vw, 1.2rem); }
  @media (min-width: 720px) {
    .bento { grid-template-columns: repeat(2, 1fr); align-items: start; }
    .span2 { grid-column: 1 / -1; }
  }
  .box {
    background: var(--bone);
    border: 1px solid var(--hairline-soft);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-1);
    padding: clamp(1.3rem, 3vw, 1.9rem);
  }
  .box-title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(1.5rem, 3vw, 1.95rem);
    line-height: 1.05;
    margin: 0 0 1.1rem;
    text-transform: lowercase;
    color: var(--ink);
  }
  .subh { font-family: var(--sans); font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--taupe); margin: 0 0 0.7rem; display: block; }
  .subh.gap { margin-top: 1.8rem; }
  .podpair { display: grid; grid-template-columns: 1fr; gap: 1rem; }
  @media (min-width: 560px) { .podpair { grid-template-columns: 1fr 1fr; gap: 1rem 2rem; } }
  .pod { display: flex; flex-direction: column; gap: 0.2rem; }
  .hint-line { font-family: var(--sans); font-size: 0.9rem; color: var(--taupe); margin: 0 0 0.9rem; }
  .inline-link { color: var(--clay); text-decoration: none; }
  .inline-link:hover { color: var(--ox-blood); text-decoration: underline; text-underline-offset: 3px; }

  /* ── interest pills (cream, to lift off the bone box) ── */
  .interests { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: 0.55rem; }
  .interests li {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.5em 0.95em; border-radius: 999px;
    background: color-mix(in srgb, var(--cream) 65%, #fff);
    border: 1px solid var(--hairline-soft);
    font-size: 0.95rem; color: var(--ink);
  }
  .interests .emoji { font-size: 1.15rem; }

  /* ── interested-in list ── */
  .now { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.6rem; }
  .now li { position: relative; padding-left: 1.2rem; font-size: 0.98rem; line-height: 1.5; color: color-mix(in srgb, var(--ink) 88%, var(--cream)); }
  .now li::before { content: ''; position: absolute; left: 0; top: 0.6em; width: 6px; height: 6px; border-radius: 50%; background: var(--clay); }

  /* ── typographic rows (podcasts, people) with hairline dividers ── */
  .rows { list-style: none; margin: 0; padding: 0; }
  .rows li { display: flex; flex-direction: column; gap: 0.2rem; padding: 0.85rem 0; border-top: 1px solid var(--hairline-soft); }
  .rows li:first-child { border-top: none; padding-top: 0; }
  .row-h { font-family: var(--serif); font-size: 1.25rem; color: var(--ink); }
  .row-s { font-size: 0.88rem; color: var(--taupe); line-height: 1.5; }

  /* ── kitchen ── */
  .lead-name { display: block; font-family: var(--serif); font-size: 1.4rem; color: var(--ink); }
  .lead-blurb { color: color-mix(in srgb, var(--ink) 80%, var(--cream)); margin: 0.4rem 0 1rem; line-height: 1.6; max-width: 60ch; }
  .pic-row { display: grid; gap: 0.6rem; }
  .pic-row.three { grid-template-columns: repeat(3, 1fr); }
  .pic-row img { width: 100%; aspect-ratio: 4 / 5; object-fit: cover; border-radius: var(--radius); box-shadow: var(--shadow-1); }

  /* ── awards ── */
  .awards { list-style: none; margin: 0; padding: 0; }
  .awards li { padding: 1rem 0; border-top: 1px solid var(--hairline-soft); }
  .awards li:first-child { border-top: none; padding-top: 0; }
  .award-title { display: block; font-family: var(--serif); font-size: 1.25rem; color: var(--ox-blood); margin-bottom: 0.3rem; line-height: 1.15; }
  .award-body { font-size: 0.92rem; color: color-mix(in srgb, var(--ink) 80%, var(--cream)); line-height: 1.55; }

  /* ── hikes ── */
  .hikes { display: grid; grid-template-columns: 1fr 1fr; gap: 0.7rem; margin: 0 0 1.2rem; }
  .hike { margin: 0; }
  .hike img { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; border-radius: var(--radius); box-shadow: var(--shadow-1); }
  .hike figcaption { font-family: var(--sans); font-size: 0.85rem; color: var(--taupe); margin-top: 0.45rem; }
  .race { color: var(--clay); font-size: 1rem; margin: 0; }

  /* ── say hi (distinct warm tone) ── */
  .box.cookies { background: color-mix(in srgb, var(--ox-blood) 6%, var(--bone)); box-shadow: var(--shadow-2); }
  .cookie-pitch { font-size: 1.02rem; line-height: 1.6; color: color-mix(in srgb, var(--ink) 82%, var(--cream)); max-width: 54ch; margin: 0 0 1.3rem; }
  .cookie-strip { display: flex; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 1.3rem; }
  .cookie-strip img { width: 84px; height: 84px; object-fit: cover; border-radius: 12px; box-shadow: var(--shadow-1); }
  .contact { display: flex; flex-direction: column; gap: 0.7rem; }
  .row { display: flex; gap: 0.7rem; flex-wrap: wrap; }
  .row.end { align-items: center; justify-content: space-between; }
  .in {
    flex: 1 1 200px; padding: 0.8em 1em; border-radius: var(--radius);
    border: 1px solid var(--hairline); background: color-mix(in srgb, var(--cream) 40%, #fff);
    color: var(--ink); font-size: 1rem; font-family: var(--sans);
  }
  .in::placeholder { color: var(--taupe); }
  .in:focus { outline: none; border-color: var(--ox-blood); }
  .area { width: 100%; resize: vertical; }
  .contact-msg { margin: 0; font-size: 0.9rem; color: #6f7a4e; min-height: 1.2em; }
  .contact-msg.err { color: var(--clay); }
  .btn-solid {
    background: var(--ox-blood); color: var(--bone); border: none; font-weight: 600;
    font-size: 1rem; font-family: var(--sans); padding: 0.75em 1.5em; border-radius: 999px;
    cursor: pointer; box-shadow: var(--shadow-1);
    transition: background 0.25s ease, transform 0.2s ease, box-shadow 0.25s ease;
  }
  .btn-solid:hover { background: var(--ox-blood-deep); transform: translateY(-2px); box-shadow: var(--shadow-2); }

  .findme { margin-top: 1.6rem; padding-top: 1.3rem; border-top: 1px solid var(--hairline); }
  .socials { display: flex; gap: 0.7rem; flex-wrap: wrap; }
  .social { font-size: 0.95rem; text-decoration: none; color: var(--ink); padding: 0.55em 1.1em; border-radius: 999px; border: 1px solid var(--hairline); background: var(--bone); transition: transform 0.2s ease, border-color 0.25s ease, color 0.25s ease; }
  .social:hover { transform: translateY(-2px); border-color: var(--ox-blood); color: var(--ox-blood); }

  .me-foot { margin-top: clamp(3rem, 7vw, 5rem); font-size: 0.82rem; color: var(--taupe); letter-spacing: 0.04em; text-align: center; }

  /* ── Slim nav: sticky top bar (mobile) → fixed left rail (wide desktop) ── */
  .nav {
    position: sticky; top: 0; z-index: 20;
    display: flex; gap: 1.3rem; justify-content: center; align-items: center;
    padding: 0.75rem 1rem;
    background: color-mix(in srgb, var(--cream) 80%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--hairline-soft);
    overflow-x: auto;
  }
  .nav a { font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--taupe); text-decoration: none; white-space: nowrap; transition: color 0.25s ease; }
  .nav a:hover, .nav a.active { color: var(--ox-blood); }

  @media (min-width: 1240px) {
    .nav {
      position: fixed; left: calc((100vw - 960px) / 2 - 7rem); top: 50%; transform: translateY(-50%);
      flex-direction: column; align-items: flex-start; gap: 1rem; width: 6rem;
      padding: 0; background: none; backdrop-filter: none; border: none; overflow: visible;
    }
    .nav a { position: relative; }
    .nav a.active { padding-left: 1.1rem; }
    .nav a.active::before { content: ''; position: absolute; left: 0; top: 50%; width: 0.7rem; height: 1px; background: var(--ox-blood); }
  }

  /* ── Gentle fade-and-rise on entry (only when JS is on) ── */
  :global(html.js) .reveal { opacity: 0; transform: translateY(16px); transition: opacity 0.5s ease, transform 0.5s ease; }
  :global(html.js) .reveal.in-view { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) {
    :global(html.js) .reveal { opacity: 1; transform: none; transition: none; }
  }
</style>
