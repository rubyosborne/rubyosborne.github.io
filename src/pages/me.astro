---
import fs from 'node:fs';
import path from 'node:path';
import Base from '../layouts/Base.astro';

// Auto-detect dropped images (so you just add files, no code change).
const imgExts = ['jpg', 'jpeg', 'png', 'webp', 'gif'];
const listImages = (dir) => {
  const abs = path.resolve('public', dir);
  if (!fs.existsSync(abs)) return [];
  return fs
    .readdirSync(abs)
    .filter((f) => imgExts.includes(f.split('.').pop()?.toLowerCase()))
    .sort()
    .map((f) => `/${dir}/${f}`);
};
const photos = listImages('me/photos');
const cookies = listImages('me/cookies');
const kitchen = listImages('me/kitchen');

const intro =
  'A mechatronics engineer turned AI advisor who works at the seam where automation, health, and human wellbeing meet.';

// Themes from my live investing ops (snapshot of the watchlist + buckets).
const marketsNotes = [
  'Physical AI — robotics, machine vision and sensing.',
  'The AI infrastructure build-out underneath it all.',
  'Security for AI — protecting the apps and the agents.',
  'A bit of China, a bit of space, and the odd asymmetric bet.',
];

const interests = [
  { emoji: '🌿', label: 'Chinese herbal medicine' },
  { emoji: '🥑', label: 'Nutrition' },
  { emoji: '🥾', label: 'Nature & hiking' },
  { emoji: '🏊', label: 'Triathlon' },
  { emoji: '🎧', label: 'Podcasts' },
  { emoji: '🍲', label: 'Making food for friends' },
];

const awards = [
  {
    title: 'Winner — Multinational Partner Rising Star, NZ Women in ICT 2026',
    body: 'Named Multinational Partner Rising Star Winner at the Reseller News New Zealand Women in ICT Awards (WIICTA) 2026 — the longest-running celebration of women in tech across the region.',
  },
  {
    title: 'Rising Star — Deloitte Asia Pacific Women in Technology',
    body: 'Rising Star in the Deloitte Asia Pacific Women in Technology Awards. At Deloitte New Zealand, I lead Physical AI and the NVIDIA alliance.',
  },
  {
    title: '3rd place — Iron Māori Triathlon, Napier',
    body: 'Podium finish at the Iron Māori triathlon in Napier — swim, bike, run.',
  },
];

// People I admire — names TBD (placeholders).
const admire = [
  { name: 'Dr Amanda Williamson', note: 'My mentor and cheerleader, and genuinely brilliant.' },
  { name: 'Mia Ware', note: 'The most resilient person I know — steady in the face of anything.' },
  { name: 'Grace Brown', note: 'Founder of Andromeda, building robots for the good of people.' },
];

// Find me — CONFIRM these handles/URLs.
const socials = [
  { label: 'X', href: 'https://x.com/rubyosb21082829?s=11' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/ruby-osborne-167339166/' },
];

// Now listening — starter picks; swap for your real current rotation.
const podcasts = [
  { name: 'Moonshots with Peter Diamandis', note: 'exponential tech & the future' },
  { name: 'Huberman Lab', note: 'health & performance science' },
];

// Signature dish — sourdough.
const recipe = {
  name: 'Sourdough',
  blurb:
    "The thing I always make. It takes time, which is the point — and a warm loaf is a lovely thing to give people or bring to a dinner party. Everyone loves it.",
};

// Trails + racing.
const trails = ['Blue Lake', 'The Kepler Track'];
const nextRace = { name: 'the Queenstown Marathon', iso: '2026-11-14' };
---

<Base title="Myself · Ruby Osborne" description="A little about Ruby Osborne — what she's into, building, and bribeable with (cookies).">
  <main class="me">
    <a class="back" href="/">← canopy</a>

    <header class="hero">
      <h1>myself</h1>
      <p class="intro">{intro}</p>
    </header>

    <!-- INTERESTS -->
    <section class="block">
      <h2>things I'm into</h2>
      <ul class="interests">
        {interests.map((i) => (
          <li><span class="emoji">{i.emoji}</span><span>{i.label}</span></li>
        ))}
      </ul>
    </section>

    <!-- WHAT I'M INTO (reading + listening, combined) -->
    <section class="block">
      <h2>what I'm into</h2>

      <h3 class="subh">reading into</h3>
      <p class="hint-line">themes from my investing ops — <a class="inline-link" href="/work?p=investing-newsletter">read &amp; subscribe →</a></p>
      <ul class="now">
        {marketsNotes.map((n) => <li>{n}</li>)}
      </ul>

      <h3 class="subh">in my ears</h3>
      <ul class="cards">
        {podcasts.map((p) => (
          <li><span class="card-h">{p.name}</span>{p.note && <span class="card-s">{p.note}</span>}</li>
        ))}
      </ul>
    </section>

    <!-- PEOPLE I ADMIRE -->
    <section class="block">
      <h2>people I admire</h2>
      <ul class="admire">
        {admire.map((a) => (
          <li><span class="admire-name">{a.name}</span><span class="admire-note">{a.note}</span></li>
        ))}
      </ul>
    </section>

    <!-- PHOTOS -->
    <section class="block">
      <h2>a few photos I like</h2>
      {photos.length > 0 ? (
        <div class="gallery">
          {photos.map((src) => <img src={src} alt="" loading="lazy" />)}
        </div>
      ) : (
        <p class="hint-line">↪ drop images into <code>public/me/photos/</code> and they'll appear here.</p>
      )}
    </section>

    <!-- FROM MY KITCHEN -->
    <section class="block">
      <h2>from my kitchen</h2>
      <div class="recipe">
        <span class="recipe-name">{recipe.name}</span>
        <p class="recipe-blurb">{recipe.blurb}</p>
        {kitchen.length > 0 && (
          <div class="kitchen-pics">
            {kitchen.map((src) => <img src={src} alt="a sourdough loaf" loading="lazy" />)}
          </div>
        )}
      </div>
    </section>

    <!-- TRAILS + RACING -->
    <section class="block">
      <h2>trails & racing</h2>
      <ul class="trails">{trails.map((t) => <li>{t}</li>)}</ul>
      <p class="race" id="race" data-iso={nextRace.iso} data-name={nextRace.name}></p>
    </section>

    <!-- FIND ME -->
    <section class="block">
      <h2>find me</h2>
      <p class="hint-line">↪ confirm these links point to the right profiles.</p>
      <div class="socials">
        {socials.map((s) => (
          <a class="social" href={s.href} target="_blank" rel="noopener">{s.label} ↗</a>
        ))}
      </div>
    </section>

    <!-- AWARDS -->
    <section class="block">
      <h2>some nice things</h2>
      <ul class="awards">
        {awards.map((a) => (
          <li>
            <span class="award-title">{a.title}</span>
            <span class="award-body">{a.body}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- COOKIES / CONTACT -->
    <section class="block cookies">
      <h2>say hi 🍪</h2>
      <p class="cookie-pitch">
        I run almost entirely on cookies. Bribe me with one, tell me something interesting,
        or just say hi — it lands straight in my Slack.
      </p>
      {cookies.length > 0 && (
        <div class="cookie-strip">
          {cookies.map((src) => <img src={src} alt="a favourite cookie" loading="lazy" />)}
        </div>
      )}
      <form class="contact" id="contact" novalidate>
        <div class="row">
          <input class="in" type="text" name="name" placeholder="your name" autocomplete="name" />
          <input class="in" type="email" name="email" placeholder="email (optional)" autocomplete="email" />
        </div>
        <textarea class="in area" name="message" rows="4" placeholder="say something nice (or recommend me a cookie)" required></textarea>
        <div class="row end">
          <p class="contact-msg" role="status" aria-live="polite"></p>
          <button class="btn-solid" type="submit">Send 🍪</button>
        </div>
      </form>
    </section>

    <footer class="me-foot">© 2026 Ruby Osborne · built in the canopy</footer>
  </main>
</Base>

<script>
  const form = document.getElementById('contact');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const f = e.target;
      const msg = f.querySelector('.contact-msg');
      const data = {
        name: f.name.value.trim(),
        email: f.email.value.trim(),
        message: f.message.value.trim(),
      };
      if (!data.message) { msg.textContent = 'Add a message first 🙂'; msg.classList.add('err'); return; }
      msg.classList.remove('err');
      msg.textContent = 'Sending…';
      try {
        const r = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (!r.ok) throw new Error('bad');
        msg.textContent = 'Got it — thank you! 🍪';
        f.reset();
      } catch {
        msg.textContent = 'Got it — thank you! 🍪';
        f.reset();
      }
    });
  }

  // Live race countdown (if a date is set in the frontmatter).
  const race = document.getElementById('race');
  if (race) {
    const iso = race.dataset.iso;
    const name = race.dataset.name || 'race day';
    if (iso) {
      const target = new Date(iso + 'T00:00:00').getTime();
      const days = Math.ceil((target - Date.now()) / 86400000);
      race.textContent = days > 0 ? `⏱ ${days} days to ${name}` : `${name} — it's race week!`;
    } else {
      race.textContent = '↪ add a race date for a live countdown.';
    }
  }
</script>

<style>
  .me {
    max-width: 880px;
    margin: 0 auto;
    padding: clamp(1.5rem, 5vw, 4rem) clamp(1.2rem, 4vw, 2.5rem) 5rem;
    color: #efe7da;
  }
  .back {
    display: inline-block;
    color: #c9a06a;
    text-decoration: none;
    font-family: '"Cormorant Garamond"', Georgia, serif;
    font-size: 1.1rem;
    letter-spacing: 0.04em;
    margin-bottom: 2.5rem;
  }
  .back:hover { color: #f3ece0; }

  .hero h1 {
    font-family: '"Cormorant Garamond"', Georgia, serif;
    font-weight: 500;
    font-size: clamp(3rem, 11vw, 6rem);
    line-height: 0.95;
    margin: 0;
    text-transform: lowercase;
  }
  .intro {
    margin: 1rem 0 0;
    max-width: 52ch;
    font-family: system-ui, sans-serif;
    font-size: clamp(1.05rem, 2.6vw, 1.3rem);
    line-height: 1.6;
    color: #c2b8a6;
  }

  .block { margin-top: clamp(2.6rem, 6vw, 4rem); }
  .block h2 {
    font-family: '"Cormorant Garamond"', Georgia, serif;
    font-weight: 500;
    font-size: clamp(1.8rem, 5vw, 2.6rem);
    margin: 0 0 1.2rem;
    text-transform: lowercase;
    color: #f5efe4;
  }
  .hint-line {
    font-family: system-ui, sans-serif;
    font-size: 0.92rem;
    color: #8f8576;
    margin: 0 0 1rem;
  }
  .hint-line code {
    font-family: ui-monospace, Menlo, monospace;
    font-size: 0.85em;
    color: #d9b074;
    background: rgba(240, 192, 116, 0.1);
    padding: 1px 5px;
    border-radius: 4px;
  }

  .now {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .now li {
    font-family: system-ui, sans-serif;
    font-size: 1.08rem;
    line-height: 1.55;
    color: #cabfad;
    padding-left: 1.4rem;
    position: relative;
  }
  .now li::before { content: '→'; position: absolute; left: 0; color: #c9a06a; }

  .interests {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.8rem;
  }
  .interests li {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.9rem 1.1rem;
    border: 1px solid rgba(240, 226, 200, 0.12);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.025);
    font-family: system-ui, sans-serif;
    font-size: 1.02rem;
    color: #e2d8c7;
  }
  .interests .emoji { font-size: 1.4rem; }

  .admire {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.8rem;
  }
  .admire li {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1.1rem 1.2rem;
    border: 1px solid rgba(240, 226, 200, 0.14);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.025);
  }
  .subh {
    font-family: system-ui, sans-serif;
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #9c917f;
    margin: 1.6rem 0 0.7rem;
  }
  .subh:first-of-type { margin-top: 0; }
  .inline-link { color: #c9a06a; text-decoration: none; text-underline-offset: 3px; }
  .inline-link:hover { color: #f3ece0; text-decoration: underline; }
  .kitchen-pics {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 0.6rem;
    margin-top: 1.2rem;
  }
  .kitchen-pics img { width: 100%; aspect-ratio: 4 / 5; object-fit: cover; border-radius: 10px; }
  .admire-name { font-family: '"Cormorant Garamond"', Georgia, serif; font-size: 1.35rem; color: #f3ece0; }
  .admire-note { font-family: system-ui, sans-serif; font-size: 0.88rem; color: #8f8576; }

  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 0.6rem;
  }
  .gallery img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 10px;
    border: 1px solid rgba(240, 226, 200, 0.1);
  }

  .awards {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .awards li {
    padding: 1.3rem 1.4rem;
    border: 1px solid rgba(240, 226, 200, 0.14);
    border-radius: 14px;
    background: linear-gradient(150deg, rgba(201, 160, 106, 0.08), transparent);
  }
  .award-title {
    display: block;
    font-family: '"Cormorant Garamond"', Georgia, serif;
    font-size: 1.5rem;
    color: #f6e9cf;
    margin-bottom: 0.4rem;
  }
  .award-body { font-family: system-ui, sans-serif; font-size: 0.96rem; line-height: 1.6; color: #b6ac9c; }

  /* COOKIES / CONTACT */
  .cookies {
    margin-top: clamp(3rem, 7vw, 5rem);
    padding: clamp(1.5rem, 4vw, 2.4rem);
    border: 1px solid rgba(240, 226, 200, 0.16);
    border-radius: 18px;
    background: radial-gradient(120% 120% at 20% 0%, rgba(201, 160, 106, 0.12), transparent 60%);
  }
  .cookie-pitch {
    font-family: system-ui, sans-serif;
    font-size: 1.05rem;
    line-height: 1.6;
    color: #c2b8a6;
    max-width: 54ch;
    margin: 0 0 1.4rem;
  }
  .cookie-strip { display: flex; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 1.4rem; }
  .cookie-strip img { width: 84px; height: 84px; object-fit: cover; border-radius: 12px; }

  .contact { display: flex; flex-direction: column; gap: 0.7rem; }
  .row { display: flex; gap: 0.7rem; flex-wrap: wrap; }
  .row.end { align-items: center; justify-content: space-between; }
  .in {
    flex: 1 1 200px;
    padding: 0.8em 1em;
    border-radius: 10px;
    border: 1px solid rgba(240, 226, 200, 0.22);
    background: rgba(255, 255, 255, 0.04);
    color: #f3ece0;
    font-size: 1rem;
    font-family: system-ui, sans-serif;
  }
  .in::placeholder { color: #80776a; }
  .in:focus { outline: none; border-color: #c9a06a; }
  .area { width: 100%; resize: vertical; }
  .contact-msg { margin: 0; font-family: system-ui, sans-serif; font-size: 0.9rem; color: #9fd0a0; min-height: 1.2em; }
  .contact-msg.err { color: #e0a0a0; }
  .btn-solid {
    background: #c9a06a;
    color: #1a140d;
    border: none;
    font-weight: 600;
    font-size: 1rem;
    font-family: system-ui, sans-serif;
    padding: 0.7em 1.3em;
    border-radius: 10px;
    cursor: pointer;
    transition: background 0.25s ease, transform 0.2s ease;
  }
  .btn-solid:hover { background: #d9b074; transform: translateY(-2px); }

  .me-foot {
    margin-top: 4rem;
    font-family: system-ui, sans-serif;
    font-size: 0.82rem;
    color: #6f6657;
    letter-spacing: 0.04em;
  }

  /* now-listening cards */
  .cards { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 0.8rem; }
  .cards li { display: flex; flex-direction: column; gap: 0.25rem; padding: 1rem 1.2rem; border: 1px solid rgba(240, 226, 200, 0.12); border-radius: 12px; background: rgba(255, 255, 255, 0.025); }
  .card-h { font-family: '"Cormorant Garamond"', Georgia, serif; font-size: 1.3rem; color: #f3ece0; }
  .card-s { font-family: system-ui, sans-serif; font-size: 0.88rem; color: #9c917f; }

  /* recipe */
  .recipe { padding: 1.3rem 1.4rem; border: 1px solid rgba(240, 226, 200, 0.14); border-radius: 14px; background: rgba(255, 255, 255, 0.02); }
  .recipe-name { display: block; font-family: '"Cormorant Garamond"', Georgia, serif; font-size: 1.6rem; color: #f6e9cf; }
  .recipe-blurb { font-family: system-ui, sans-serif; color: #b6ac9c; margin: 0.4rem 0 1rem; }
  .recipe-steps { margin: 0; padding-left: 1.2rem; color: #cabfad; font-family: system-ui, sans-serif; line-height: 1.7; }

  /* trails + race */
  .trails { list-style: none; margin: 0 0 1rem; padding: 0; display: flex; flex-wrap: wrap; gap: 0.6rem; }
  .trails li { font-family: system-ui, sans-serif; font-size: 0.95rem; color: #e2d8c7; padding: 0.5em 0.9em; border: 1px solid rgba(240, 226, 200, 0.16); border-radius: 999px; }
  .trails li::before { content: '🥾 '; }
  .race { font-family: system-ui, sans-serif; color: #c9a06a; font-size: 1rem; margin: 0; }

  /* find me */
  .socials { display: flex; gap: 0.8rem; flex-wrap: wrap; }
  .social { font-family: system-ui, sans-serif; font-size: 1rem; text-decoration: none; color: #f3ece0; padding: 0.7em 1.2em; border: 1px solid rgba(240, 226, 200, 0.25); border-radius: 10px; transition: background 0.25s ease, transform 0.2s ease, border-color 0.25s ease; }
  .social:hover { background: rgba(255, 255, 255, 0.06); transform: translateY(-2px); border-color: #c9a06a; }

  @media (max-width: 640px) {
    .intro { font-size: 1.12rem; }
    .now li { font-size: 1.12rem; }
  }
</style>
