---
import Base from '../layouts/Base.astro';
import '../styles/theme.css';
---

<Base title="Tend Robotics · preread" description="Password-protected preread.">
  <main class="deck">
    <!-- Locked state: password gate -->
    <section class="gate" id="gate">
      <a class="back" href="/work">← work</a>
      <div class="gate-card">
        <h1>Tend Robotics</h1>
        <p class="gate-sub">This preread is password-protected.</p>
        <form class="gate-form" id="unlock" novalidate>
          <input class="pw" id="pw" type="password" placeholder="password" autocomplete="off" autocapitalize="off" spellcheck="false" />
          <button class="btn-solid" type="submit">View</button>
        </form>
        <p class="gate-msg" id="msg" role="status" aria-live="polite"></p>
      </div>
    </section>

    <!-- Unlocked state: inline PDF reader -->
    <section class="viewer is-hidden" id="viewer">
      <header class="viewer-bar">
        <a class="back back-bar" href="/work">← work</a>
        <span class="viewer-title">Tend Robotics · preread</span>
      </header>
      <div class="scroll" id="scroll">
        <p class="loading" id="loading" role="status" aria-live="polite">
          <span class="spinner" aria-hidden="true"></span> Loading preread…
        </p>
        <div class="pages" id="pages"></div>
      </div>
    </section>
  </main>
</Base>

<script>
  import * as pdfjsLib from 'pdfjs-dist';
  import workerUrl from 'pdfjs-dist/build/pdf.worker.min.mjs?url';

  pdfjsLib.GlobalWorkerOptions.workerSrc = workerUrl;

  const form = document.getElementById('unlock');
  const msg = document.getElementById('msg');
  const gate = document.getElementById('gate');
  const viewer = document.getElementById('viewer');
  const pagesEl = document.getElementById('pages');
  const loadingEl = document.getElementById('loading');

  // Cap device-pixel-ratio so huge canvases don't blow memory on phones,
  // while still rendering crisp text on retina displays.
  const DPR = Math.min(window.devicePixelRatio || 1, 2);
  const MAX_PAGE_WIDTH = 900;

  let pdfDoc = null;
  let started = false;
  let renderToken = 0;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const pw = document.getElementById('pw').value;
    msg.textContent = 'Checking…';
    msg.classList.remove('err');
    try {
      const r = await fetch('/api/deck-auth', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password: pw }),
      });
      if (r.ok) {
        gate.classList.add('is-hidden');
        viewer.classList.remove('is-hidden');
        await loadPdf();
      } else {
        msg.textContent = 'Wrong password.';
        msg.classList.add('err');
      }
    } catch {
      msg.textContent = 'Something went wrong, try again.';
      msg.classList.add('err');
    }
  });

  async function loadPdf() {
    if (started) return;
    started = true;
    try {
      // The auth cookie (HttpOnly) is sent automatically with same-origin creds.
      const res = await fetch('/protected/tend-robotics.pdf', { credentials: 'same-origin' });
      if (!res.ok) throw new Error('fetch failed');
      const data = await res.arrayBuffer();
      pdfDoc = await pdfjsLib.getDocument({ data }).promise;
      await renderAll();
      loadingEl.classList.add('is-hidden');
    } catch {
      loadingEl.textContent = 'Could not load the document. Reload the page and try again.';
    }
  }

  // Available CSS-pixel width for a page (content box of .pages).
  function availableWidth() {
    const cs = getComputedStyle(pagesEl);
    const pad = parseFloat(cs.paddingLeft) + parseFloat(cs.paddingRight);
    return Math.max(240, Math.min(pagesEl.clientWidth - pad, MAX_PAGE_WIDTH));
  }

  async function renderAll() {
    if (!pdfDoc) return;
    const token = ++renderToken;
    const targetW = availableWidth();
    pagesEl.querySelectorAll('canvas').forEach((c) => c.remove());

    for (let n = 1; n <= pdfDoc.numPages; n++) {
      if (token !== renderToken) return; // a newer resize render superseded us
      const page = await pdfDoc.getPage(n);
      const base = page.getViewport({ scale: 1 });
      const scale = targetW / base.width;
      const viewport = page.getViewport({ scale: scale * DPR });

      const canvas = document.createElement('canvas');
      canvas.className = 'pdf-page';
      canvas.width = Math.floor(viewport.width);
      canvas.height = Math.floor(viewport.height);
      canvas.style.width = Math.floor(viewport.width / DPR) + 'px';
      canvas.style.height = Math.floor(viewport.height / DPR) + 'px';
      pagesEl.appendChild(canvas);

      await page.render({ canvasContext: canvas.getContext('2d'), viewport }).promise;
    }
  }

  // Re-fit pages on resize / orientation change (debounced).
  let resizeTimer;
  window.addEventListener('resize', () => {
    if (!pdfDoc) return;
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(renderAll, 200);
  });
</script>

<style>
  :global(body) {
    background-color: var(--cream);
    background-image: var(--daylight);
    background-attachment: fixed;
    color: var(--ink);
    margin: 0;
  }
  .deck { font-family: var(--sans); }

  .is-hidden { display: none !important; }

  .back {
    display: inline-block;
    color: var(--clay);
    text-decoration: none;
    font-family: var(--serif);
    font-size: 1.05rem;
    letter-spacing: 0.02em;
  }
  .back:hover { color: var(--ox-blood); }

  /* Locked gate */
  .gate {
    min-height: 100dvh;
    display: grid;
    place-items: center;
    padding: 2rem 1.2rem;
    position: relative;
  }
  .gate .back { position: absolute; top: clamp(1.4rem, 4vw, 2.5rem); left: clamp(1.2rem, 4vw, 2.5rem); }
  .gate-card {
    width: min(420px, 100%);
    background: var(--bone);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-2);
    padding: clamp(1.6rem, 5vw, 2.6rem);
    text-align: left;
  }
  .gate-card h1 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(2rem, 6vw, 2.8rem);
    color: var(--ox-blood);
    margin: 0;
    line-height: 1;
  }
  .gate-sub { color: var(--taupe); font-size: 0.95rem; margin: 0.7rem 0 1.6rem; }
  .gate-form { display: flex; gap: 0.6rem; flex-wrap: wrap; }
  .pw {
    flex: 1 1 200px;
    padding: 0.8em 1em;
    border-radius: var(--radius);
    border: 1px solid var(--hairline);
    background: color-mix(in srgb, var(--cream) 40%, #fff);
    color: var(--ink);
    font-size: 1rem;
    font-family: var(--sans);
  }
  .pw::placeholder { color: var(--taupe); }
  .pw:focus { outline: none; border-color: var(--ox-blood); }
  .btn-solid {
    background: var(--ox-blood);
    color: var(--bone);
    border: none;
    font-weight: 600;
    font-size: 1rem;
    font-family: var(--sans);
    padding: 0.75em 1.4em;
    border-radius: 999px;
    cursor: pointer;
    box-shadow: var(--shadow-1);
    transition: background 0.25s ease, transform 0.2s ease, box-shadow 0.25s ease;
  }
  .btn-solid:hover { background: var(--ox-blood-deep); transform: translateY(-2px); box-shadow: var(--shadow-2); }
  .gate-msg { min-height: 1.2em; margin: 0.9rem 0 0; font-size: 0.9rem; color: var(--taupe); }
  .gate-msg.err { color: var(--clay); }

  /* Unlocked reader */
  .viewer { display: flex; flex-direction: column; height: 100dvh; }
  .viewer-bar {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.7rem clamp(1rem, 3vw, 1.6rem);
    background: color-mix(in srgb, var(--cream) 88%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--hairline-soft);
    z-index: 2;
  }
  .back-bar { font-size: 1rem; }
  .viewer-title { font-family: var(--serif); color: var(--ink); font-size: 1.05rem; }

  .scroll {
    flex: 1 1 auto;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior: contain;
    background: color-mix(in srgb, var(--cream) 55%, #cabfae);
  }
  .loading {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    color: var(--taupe);
    font-size: 0.95rem;
    padding: 3rem 1rem;
    margin: 0;
  }
  .spinner {
    width: 1.05em;
    height: 1.05em;
    border: 2px solid color-mix(in srgb, var(--clay) 35%, transparent);
    border-top-color: var(--ox-blood);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .pages {
    max-width: 900px;
    margin: 0 auto;
    padding: clamp(0.75rem, 3vw, 1.6rem) clamp(0.5rem, 3vw, 1.6rem) clamp(4rem, 10vw, 6rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(0.75rem, 2.5vw, 1.4rem);
  }
  .pdf-page {
    max-width: 100%;
    height: auto;
    display: block;
    background: #fff;
    border-radius: 2px;
    box-shadow: var(--shadow-2);
  }
</style>
