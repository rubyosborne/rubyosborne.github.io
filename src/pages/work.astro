---
import fs from 'node:fs';
import path from 'node:path';
import Base from '../layouts/Base.astro';
import '../styles/theme.css';
import { projects } from '../data/projects.js';

const monogram = (n) =>
  n.replace(/[^A-Za-z ]/g, '').split(/\s+/).filter(Boolean).slice(0, 2).map((w) => w[0]).join('').toUpperCase();
const badgeText = (s) => (s === 'dev' ? 'In development' : s === 'training' ? 'In training' : 'Discontinued');

// Display order (Trading Bot sits 3rd-to-last).
const order = [
  'long-term-investing-bot',
  'investing-newsletter',
  'life-operating-system',
  'tallow-lab',
  'tend-robotics',
  'closed-loop-hydroponic-farm',
  'trading-bot',
  'born-nutrition',
  'personal-writing-style',
];

// Auto-detect a per-project image: drop /public/projects/<id>.{jpg,png,webp,svg}
// and it shows automatically (no code change needed).
const exts = ['jpg', 'jpeg', 'png', 'webp', 'svg'];
const findImg = (id) => {
  for (const e of exts) {
    if (fs.existsSync(path.resolve('public/projects', `${id}.${e}`))) return `/projects/${id}.${e}`;
  }
  return null;
};
const items = order
  .map((id) => projects.find((p) => p.id === id))
  .filter(Boolean)
  .map((p) => ({ ...p, img: findImg(p.id) }));
---

<Base title="My Work · Ruby Osborne" description="Projects by Ruby Osborne, finance systems, robotics, products and tools.">
  <main class="work">
    <a class="back" href="/">← canopy</a>

    <header class="work-head">
      <h1>my work</h1>
    </header>

    <ul class="grid" id="grid">
      {items.map((p) => (
        <li>
          <button class="card" type="button" data-id={p.id} aria-label={`Open ${p.name}`}>
            <span class="media" style={`--accent:${p.accent}`}>
              {p.img
                ? <img src={p.img} class={p.logo ? 'logo' : ''} alt="" loading="lazy" />
                : <span class="mono" aria-hidden="true">{monogram(p.name)}</span>}
              {p.status && <span class={`badge badge--${p.status}`}>{badgeText(p.status)}</span>}
            </span>
            <span class="card-body">
              <span class="tag">{p.tag}</span>
              <span class="name">{p.name}</span>
              <span class="short">{p.short}</span>
              <span class="cta">View <span class="arrow">→</span></span>
            </span>
          </button>
        </li>
      ))}
    </ul>
  </main>

  <!-- Expand overlay (one detail per project; the active one animates from its card) -->
  <div class="overlay" id="overlay" hidden>
    <div class="backdrop" id="backdrop" data-close></div>
    <div class="stage">
      {items.map((p) => (
        <article class="detail" id={`detail-${p.id}`} hidden>
          <button class="close" type="button" aria-label="Close" data-close>×</button>
          <div class="detail-media" style={`--accent:${p.accent}`}>
            {p.img
              ? <img src={p.img} class={p.logo ? 'logo' : ''} alt="" />
              : <span class="mono" aria-hidden="true">{monogram(p.name)}</span>}
            {p.status && <span class={`badge badge--${p.status}`}>{badgeText(p.status)}</span>}
          </div>
          <div class="detail-body">
            <span class="tag">{p.tag}</span>
            <h2>{p.name}</h2>
            <div class="long" set:html={p.long} />

            {p.links && p.links.length > 0 && (
              <div class="actions">
                {p.links.map((l) => (
                  <a class="btn" href={l.href} target="_blank" rel="noopener">{l.label} →</a>
                ))}
              </div>
            )}

            {p.download && (
              <div class="actions">
                <a class="btn btn--solid" href={p.download.href} download>{p.download.label} ↓</a>
              </div>
            )}

            {p.email && (
              <form class="subscribe" data-project={p.id} novalidate>
                <label class="subscribe-label" for={`email-${p.id}`}>Join the newsletter</label>
                <div class="subscribe-row">
                  <input id={`email-${p.id}`} class="subscribe-input" type="email" name="email" placeholder="you@email.com" required autocomplete="email" />
                  <button class="btn btn--solid" type="submit">Subscribe</button>
                </div>
                <p class="subscribe-msg" role="status" aria-live="polite"></p>
              </form>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</Base>

<script>
  import { initProjects } from '../scripts/projects';
  initProjects();
</script>

<style>
  /* Body becomes the calm cream room: one daylight source (upper-left) + matte plaster. */
  :global(body) {
    background-color: var(--cream);
    background-image: var(--daylight);
    background-attachment: fixed;
    color: var(--ink);
  }
  :global(body)::before {
    content: '';
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background-image: var(--plaster);
    background-size: 220px 220px;
    opacity: 0.05;
    mix-blend-mode: multiply;
  }

  .work {
    min-height: 100vh;
    max-width: 1180px;
    margin: 0 auto;
    padding: clamp(2rem, 5vw, 5rem) clamp(1.5rem, 4vw, 3rem) 7rem;
    color: var(--ink);
    font-family: var(--sans);
  }
  .back {
    display: inline-block;
    color: var(--clay);
    text-decoration: none;
    font-family: var(--serif);
    font-size: 1.15rem;
    letter-spacing: 0.02em;
    margin-bottom: 3rem;
  }
  .back:hover { color: var(--ox-blood); }

  .work-head { margin-bottom: clamp(2.5rem, 6vw, 4.5rem); }
  .work-head h1 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(2.8rem, 9vw, 5.5rem);
    line-height: 1;
    margin: 0;
    text-transform: lowercase;
    letter-spacing: 0.005em;
    color: var(--ox-blood);
  }
  .lede {
    margin: 1.1rem 0 0;
    max-width: 48ch;
    color: var(--taupe);
    font-size: clamp(1.05rem, 2.4vw, 1.2rem);
    line-height: 1.65;
  }

  /* Cards */
  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: clamp(1rem, 2vw, 1.5rem);
  }
  /* ── Photo tiles: one full-bleed photo, title overlaid lower-left, quiet at rest ── */
  .card {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    text-align: left;
    background: var(--bone);
    border: 1px solid var(--hairline-soft);
    border-radius: var(--radius-lg);
    overflow: hidden;
    cursor: pointer;
    color: inherit;
    font: inherit;
    padding: 0;
    display: block;
    box-shadow: var(--shadow-1);
    transition: transform 0.5s ease, box-shadow 0.45s ease;
    will-change: transform;
  }
  .card:hover,
  .card:focus-visible {
    box-shadow: var(--shadow-2);
    outline: none;
  }

  /* full-bleed media fills the tile (muted named placeholder until a photo is dropped in) */
  .media {
    position: absolute;
    inset: 0;
    background:
      var(--daylight),
      linear-gradient(150deg, color-mix(in srgb, var(--accent) 28%, var(--bone)), color-mix(in srgb, var(--accent) 12%, var(--cream)));
    overflow: hidden;
  }
  .media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .card:hover .media img,
  .card:focus-visible .media img { transform: scale(1.03); }
  .media img.logo,
  .detail-media img.logo { object-fit: contain; padding: 12%; }

  /* understated dark scrim, transparent up top, a subtle dark at the lower edge for legible white */
  .media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(18, 10, 8, 0.55), rgba(18, 10, 8, 0.14) 32%, transparent 55%);
    pointer-events: none;
  }

  .mono { display: none; }        /* the overlaid title names the tile now */
  .card .badge { display: none; } /* nothing but the title at rest; status still shows when expanded */

  /* title overlay, anchored lower-left */
  .card-body {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
    padding: clamp(1rem, 2.5vw, 1.4rem) clamp(1.1rem, 2.5vw, 1.5rem);
    display: block;
    transition: transform 0.4s ease;
  }
  .card:hover .card-body,
  .card:focus-visible .card-body { transform: translateY(-5px); }
  .card-body .tag,
  .card-body .short,
  .card-body .cta { display: none; }
  .name {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(1.5rem, 2.6vw, 1.9rem);
    line-height: 1.12;
    color: #fff;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.28);
  }

  /* Expand overlay */
  .overlay { position: fixed; inset: 0; z-index: 100; }
  .overlay[hidden] { display: none; }
  .backdrop {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--ink) 48%, transparent);
    backdrop-filter: blur(4px);
    opacity: 0;
  }
  .stage {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    padding: clamp(0.8rem, 3vw, 2rem);
    pointer-events: none;
  }
  .detail {
    pointer-events: auto;
    position: relative;
    width: min(760px, 100%);
    max-height: 88vh;
    overflow: auto;
    background: var(--bone);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-2);
    will-change: transform, opacity;
  }
  .detail[hidden] { display: none; }
  .close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 3;
    width: 2.3rem;
    height: 2.3rem;
    border-radius: 50%;
    border: 1px solid var(--hairline);
    background: color-mix(in srgb, var(--bone) 85%, transparent);
    backdrop-filter: blur(4px);
    color: var(--ink);
    font-size: 1.4rem;
    line-height: 1;
    cursor: pointer;
    transition: background 0.25s ease, transform 0.25s ease;
  }
  .close:hover { background: color-mix(in srgb, var(--clay) 14%, var(--bone)); transform: rotate(90deg); }

  .detail-media {
    position: relative;
    aspect-ratio: 16 / 8;
    background:
      var(--daylight),
      linear-gradient(150deg, color-mix(in srgb, var(--accent) 30%, var(--bone)), color-mix(in srgb, var(--accent) 12%, var(--cream)));
    display: grid;
    place-items: center;
    overflow: hidden;
  }
  .detail-media img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }

  .detail-body { padding: clamp(1.6rem, 4vw, 2.6rem); }
  .detail-body h2 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(2.1rem, 5vw, 3.1rem);
    line-height: 1.05;
    margin: 0.3rem 0 1.2rem;
    color: var(--ox-blood);
  }
  .long :global(p) {
    font-family: var(--sans);
    font-size: 1.02rem;
    line-height: 1.72;
    color: color-mix(in srgb, var(--ink) 82%, var(--cream));
    margin: 0 0 1rem;
  }
  .long :global(a) { color: var(--clay); text-underline-offset: 3px; }
  .long :global(a):hover { color: var(--ox-blood); }

  .actions { margin-top: 1.6rem; display: flex; flex-wrap: wrap; gap: 0.8rem; }
  .btn {
    font-family: var(--sans);
    font-size: 0.92rem;
    letter-spacing: 0.01em;
    text-decoration: none;
    padding: 0.75em 1.2em;
    border-radius: 12px;
    border: 1px solid color-mix(in srgb, var(--ox-blood) 45%, transparent);
    color: var(--ox-blood);
    cursor: pointer;
    background: transparent;
    transition: background 0.25s ease, border-color 0.25s ease, transform 0.2s ease;
  }
  .btn:hover { background: color-mix(in srgb, var(--ox-blood) 8%, transparent); transform: translateY(-2px); }
  .btn--solid { background: var(--ox-blood); color: var(--bone); border-color: var(--ox-blood); font-weight: 600; }
  .btn--solid:hover { background: var(--ox-blood-deep); }

  .subscribe { margin-top: 1.8rem; }
  .subscribe-label {
    display: block;
    font-family: var(--sans);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--taupe);
    margin-bottom: 0.6rem;
  }
  .subscribe-row { display: flex; flex-wrap: wrap; gap: 0.6rem; }
  .subscribe-input {
    flex: 1 1 220px;
    padding: 0.8em 1em;
    border-radius: 12px;
    border: 1px solid var(--hairline);
    background: color-mix(in srgb, var(--cream) 55%, #fff);
    color: var(--ink);
    font-size: 0.98rem;
    font-family: var(--sans);
  }
  .subscribe-input::placeholder { color: var(--taupe); }
  .subscribe-input:focus { outline: none; border-color: var(--ox-blood); }
  .subscribe-msg { margin: 0.7rem 0 0; font-family: var(--sans); font-size: 0.88rem; color: #6f7a4e; min-height: 1.2em; }
  .subscribe-msg.err { color: var(--clay); }

  @media (max-width: 640px) {
    .work-head h1 { font-size: clamp(3rem, 14vw, 4.4rem); }
    .lede { font-size: 1.1rem; }
    .grid { grid-template-columns: 1fr; gap: 1.3rem; }
    .name { font-size: 1.8rem; }
    .short { font-size: 1.04rem; line-height: 1.62; }
    .tag { font-size: 0.76rem; }
    .cta { font-size: 0.92rem; }
    .detail-body h2 { font-size: clamp(2.2rem, 9vw, 3rem); }
    .long :global(p) { font-size: 1.08rem; line-height: 1.75; }
    .btn { font-size: 1rem; }
    .subscribe-input { font-size: 1.02rem; }
  }
  @media (max-width: 560px) {
    .detail { border-radius: var(--radius); max-height: 92vh; }
  }
</style>
